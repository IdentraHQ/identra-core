# Identra Environment Configuration Template

# Copy this file to .env and fill in your values
# Example: cp .env.example .env

# ============================================================
# Brain Service (FastAPI)
# ============================================================

# Host to bind the Brain service to
BRAIN_HOST=127.0.0.1

# Port to bind the Brain service to
BRAIN_PORT=8000

# Log level (DEBUG, INFO, WARNING, ERROR)
LOG_LEVEL=INFO

# ============================================================
# Ollama Integration (Local LLM Runtime)
# ============================================================

# Ollama server URL (default: localhost:11434)
OLLAMA_URL=http://localhost:11434

# Model to use for inference
# Recommended: llama3, mistral, neural-chat, dolphin-mixtral
OLLAMA_MODEL=llama3

# Inference timeout in seconds
OLLAMA_TIMEOUT=120

# ============================================================
# Memory System (ChromaDB)
# ============================================================

# ChromaDB database path (defaults to ~/.identra/chroma_db)
CHROMA_DB_PATH=~/.identra/chroma_db

# Memory retrieval limit (max memories to fetch per query)
MEMORY_TOP_K=5

# Similarity threshold for memory deduplication (0.0 to 1.0)
# Lower = more strict dedup (0.1 means distance < 0.1)
MEMORY_DEDUP_THRESHOLD=0.1

# ============================================================
# Desktop App Configuration (Tauri)
# ============================================================

# Brain service URL for desktop client
# Should match BRAIN_HOST:BRAIN_PORT
BRAIN_API_URL=http://127.0.0.1:8000

# Enable debug mode in desktop app
DEBUG_MODE=false

# ============================================================
# Security & Encryption
# ============================================================

# Path to AES-256 encryption key file
# Auto-generated at ~/.identra/.key if not present
VAULT_KEY_PATH=~/.identra/.key

# ============================================================
# Development & Debugging
# ============================================================

# Setup verbose logging
SETUP_DEBUG=false

# Watchdog check interval (seconds)
WATCHDOG_INTERVAL=5

# Max retries for Brain startup
BRAIN_STARTUP_MAX_RETRIES=5

# ============================================================
# Notes
# ============================================================
# - All paths using ~ will expand to $HOME automatically
# - Leave blank to use defaults (safe for first launch)
# - See README.md for troubleshooting
